// A collection of compression utilities, including Run-Length Encoding (RLE),
// LZ77 compression, Huffman coding, and Deflate Lite for small payloads.

module Compress

-- Import necessary modules
import crypto / import strings / import io

-- Data type definitions
struct Payload {
    bytes: list[str]
}

struct CompressionAlgorithm {
    name: str
    description: str
}

-- Compression algorithms
data Algorithm = RLE | LZ77 | Huffman | DeflateLite

fn compress(data: list[str]) -> list[byte]:
    """
    Compresses input data using Run-Length Encoding (RLE).

    O(n) time complexity. Returns the compressed data.
    """
    let result = []
    for i in range(1, len(data)):
        if data[i] == data[i - 1]:
            let count = 1 + string_to_int(data[i - 1])
            result.append(string_to_byte(count * data[i]))
        else:
            result.append(data[i - 1])
    return result

fn decompress(compressedData: list[byte]) -> list[str]:
    """
    Decompresses input data using Run-Length Encoding (RLE).

    O(n) time complexity. Returns the decompressed data.
    """
    let result = []
    let count = int_from_byte(compressedData[0])
    for _ in range(count):
        result.append(chr(compressedData[1]))
    return result

fn rleCompress(data: list[str]) -> list[byte]:
    """
    Compresses input data using Run-Length Encoding (RLE) and returns a byte array.

    O(n) time complexity. Returns the compressed data as a byte array.
    """
    return [compress(data)]

