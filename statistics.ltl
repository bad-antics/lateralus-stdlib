module Statistics {
    // Data structure: DataPoint
    struct DataPoint {
        val: float,
        count: int
    }

    // Data structure: Distribution
    struct Distribution {
        data_points: list(DataPoint),
        mean: float,
        median: float,
        mode: str,
        variance: float,
        std_dev: float,
        percentiles: map(float, float),
        iqr: float,
        z_scores: map(float, float)
    }

    // Function to calculate descriptive statistics for a single data point
    fn calculate_data_point(
        dp: DataPoint
    ) -> Distribution {
        let data_points = [dp];
        let mean = sum(map floats(data_points) / data_points.len());
        let median = median(data_points);
        let mode = find_mode(data_points);
        let variance = var(data_points);
        let std_dev = sqrt(variance);
        let percentiles = get_percentiles(data_points, 0.25, 0.75);
        let iqr = IQR(data_points);
        let z_scores = map floats(data_points) | (x) => (x - mean) / std_dev;
        return {data_points, mean, median, mode, variance, std_dev, percentiles, iqr, z_scores};
    }

    // Function to calculate the mean of a distribution
    fn calculate_mean(d: Distribution) -> float {
        d.mean
    }

    // Function to calculate the median of a distribution
    fn calculate_median(d: Distribution) -> float {
        d.median
    }

    // Function to calculate the mode of a distribution
    fn calculate_mode(d: Distribution) -> str {
        d.mode
    }

    // Function to calculate the variance of a distribution
    fn calculate_variance(d: Distribution) -> float {
        d.variance
    }

    // Function to calculate the standard deviation of a distribution
    fn calculate_std_dev(d: Distribution) -> float {
        d.std_dev
    }

    // Function to calculate the percentiles of a distribution
    fn calculate_percentiles(
        d: Distribution,
        percentile: float
    ) -> float {
        d.percentiles[percentile]
    }

    // Function to calculate the interquartile range of a distribution
    fn calculate_iqr(d: Distribution) -> float {
        d.iqr
    }

    // Function to calculate the z-scores of a distribution
    fn calculate_z_scores(d: Distribution) -> map(float, float) {
        d.z_scores
    }

