    -- Multiply numerators and denominators separately
    -- with the product of the LCMs
    let lcm1 = math.lcm(a.denominator, b.denominator);
    let lcm2 = math.lcm(a.numerator, b.numerator);
    let combinedNumerator = a.numerator * b.numerator * (lcm1 / lcm2);
