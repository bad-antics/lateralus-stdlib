// =======================================================================
// LATERALUS Standard Library — testing.ltl
// Testing framework for LATERALUS programs
// =======================================================================

// --- Assertions -------------------------------------------------------

fn assert_eq(actual, expected, message: str) {
    if actual != expected {
        throw "Assertion failed: " + message + " | Expected: " + str(expected) + " | Got: " + str(actual)
    }
}

fn assert_neq(actual, unexpected, message: str) {
    if actual == unexpected {
        throw "Assertion failed: " + message + " | Expected NOT: " + str(unexpected) + " | Got: " + str(actual)
    }
}

fn assert_true(condition: bool, message: str) {
    if not condition {
        throw "Assertion failed: expected true | " + message
    }
}

fn assert_false(condition: bool, message: str) {
    if condition {
        throw "Assertion failed: expected false | " + message
    }
}

fn assert_none(value, message: str) {
    if value != none {
        throw "Assertion failed: expected none | " + message + " | Got: " + str(value)
    }
}

fn assert_not_none(value, message: str) {
    if value == none {
        throw "Assertion failed: expected non-none | " + message
    }
}

fn assert_gt(a, b, message: str) {
    if not (a > b) {
        throw "Assertion failed: " + str(a) + " > " + str(b) + " | " + message
    }
}

fn assert_gte(a, b, message: str) {
    if not (a >= b) {
        throw "Assertion failed: " + str(a) + " >= " + str(b) + " | " + message
    }
}

fn assert_lt(a, b, message: str) {
    if not (a < b) {
        throw "Assertion failed: " + str(a) + " < " + str(b) + " | " + message
    }
}

fn assert_lte(a, b, message: str) {
    if not (a <= b) {
        throw "Assertion failed: " + str(a) + " <= " + str(b) + " | " + message
    }
}

fn assert_contains(collection, item, message: str) {
    if type(collection) == "list" {
        if not contains(collection, item) {
            throw "Assertion failed: list does not contain " + str(item) + " | " + message
        }
    } else if type(collection) == "string" {
        if not contains(collection, item) {
            throw "Assertion failed: string does not contain " + str(item) + " | " + message
        }
    } else {
        throw "assert_contains: unsupported collection type " + type(collection)
    }
}

fn assert_length(collection, expected: int, message: str) {
    let actual = len(collection)
    if actual != expected {
        throw "Assertion failed: expected length " + str(expected) + ", got " + str(actual) + " | " + message
    }
}

fn assert_approx(actual: float, expected: float, tolerance: float, message: str) {
    let diff = abs(actual - expected)
    if diff > tolerance {
        throw "Assertion failed: " + str(actual) + " ~= " + str(expected) + " (tolerance " + str(tolerance) + ", diff " + str(diff) + ") | " + message
    }
}

fn assert_throws(f, message: str) {
    let caught = false
    try {
        f()
    } catch e {
        caught = true
    }
    if not caught {
        throw "Assertion failed: expected exception | " + message
    }
}

// --- Test Runner ------------------------------------------------------

fn describe(name: str, f) {
    println("  Suite: " + name)
    f()
    println("")
}

fn it(name: str, f) {
    try {
        f()
        println("    PASS  " + name)
    } catch e {
        println("    FAIL  " + name)
        println("          " + str(e))
    }
}

// --- Benchmarking -----------------------------------------------------

fn benchmark(name: str, iterations: int, f) {
    measure name {
        for i in range(iterations) {
            f()
        }
    }
    println("  Benchmark: " + name + " (" + str(iterations) + " iterations)")
}
